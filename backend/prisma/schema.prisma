// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// ====== 本機開發用 SQLite ======
// 部署到 Coolify 時，把下面改成：
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
